# Zanzibaba Platform — Production Environment Variables
# Copy this to .env.local and fill in real values.
# For Vercel, set these in the project dashboard.

# Database (Required)
# Use a production PostgreSQL URL (Neon, Supabase, AWS RDS, etc.)
DATABASE_URL="postgresql://user:password@host:5432/zanzibaba"

# NextAuth (Required)
AUTH_SECRET="generate-with-openssl-rand-64"
AUTH_URL="https://www.zanzibaba.com"

# Stripe (Required for payments)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# File Upload — Cloudinary (Required for media uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email — Resend (Required for transactional emails)
RESEND_API_KEY="re_..."
SMTP_FROM="noreply@zanzibaba.com"

# Google OAuth (Required for social login)
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# Google Maps (Required for supplier discovery)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# OpenAI (Required for AI enrichment)
OPENAI_API_KEY="sk-your-openai-api-key"

# WhatsApp Business API (Required for WhatsApp campaigns)
WHATSAPP_API_KEY="..."
WHATSAPP_PHONE_NUMBER="..."

# Apify (Required for social supplier discovery)
APIFY_API_KEY="apify_api_..."

# App
NEXT_PUBLIC_APP_URL="https://www.zanzibaba.com"
NEXT_PUBLIC_BASE_URL="https://www.zanzibaba.com"
NEXT_PUBLIC_APP_NAME="Zanzibaba"
