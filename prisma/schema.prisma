generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  BUYER
  SUPPLIER
  CONTRACTOR
  PROFESSIONAL
  ADMIN
}

enum MembershipTier {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
  VERIFIED
  FOUNDING
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CLARIFICATION
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum RFQStatus {
  DRAFT
  OPEN
  QUOTING
  AWARDED
  CLOSED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  WITHDRAWN
}

enum OrderStatus {
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  DISPUTED
}

enum ProfessionalType {
  ARCHITECT
  ENGINEER
  SURVEYOR
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?
  passwordHash    String
  name            String
  role            UserRole  @default(BUYER)
  stripeCustomerId String?
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  buyerProfile       BuyerProfile?
  supplierProfile    SupplierProfile?
  contractorProfile  ContractorProfile?
  professionalProfile ProfessionalProfile?

  rfqs         RFQ[]
  orders       Order[]        @relation("BuyerOrders")
  reviewsGiven Review[]       @relation("Reviewer")
  projects     Project[]
  messagesSent Message[]      @relation("Sender")
  messagesRecv Message[]      @relation("Receiver")
  savedItems   SavedItem[]
  subscriptions Subscription[]
  transactions Transaction[]
  manualPayments ManualPayment[]
  verifRequests VerificationRequest[]
  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BuyerProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  companyName          String?
  companyRegistration  String?
  taxId                String?
  businessType         String?
  website              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupplierProfile {
  id                  String           @id @default(cuid())
  userId              String           @unique
  companyName         String
  registrationNumber  String?
  taxId               String?
  licenseDocumentUrl  String?
  taxDocumentUrl      String?
  companyLogoUrl      String?
  coverImageUrl       String?
  companyDescription  String?
  yearEstablished     Int?
  employeeCount       Int?
  country             String           @default("Tanzania")
  city                String?
  address             String?
  serviceAreas        Json?
  website             String?
  whatsappNumber      String?
  membershipTier      MembershipTier   @default(FREE)
  membershipExpiresAt DateTime?
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verificationBadge   Boolean          @default(false)
  isFeatured          Boolean          @default(false)
  featuredExpiresAt   DateTime?
  profileViews        Int              @default(0)
  leadCount           Int              @default(0)
  responseRate        Decimal          @default(0.0)
  avgRating           Decimal          @default(0.0)
  reviewCount         Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  quotes   Quote[]
  orders   Order[]   @relation("SupplierOrders")

  @@index([city])
  @@index([country])
  @@index([membershipTier])
  @@index([verificationStatus])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([avgRating])
  @@index([city, country])
  @@index([verificationStatus, isFeatured])
}

model ContractorProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  companyName         String
  registrationNumber  String?
  taxId               String?
  licenseNumber       String?
  licenseDocumentUrl  String?
  insuranceDocumentUrl String?
  companyLogoUrl      String?
  coverImageUrl       String?
  companyDescription  String?
  yearEstablished     Int?
  teamSize            Int?
  specialties         Json?
  completedProjects   Int                @default(0)
  country             String             @default("Tanzania")
  city                String?
  address             String?
  serviceAreas        Json?
  website             String?
  whatsappNumber      String?
  membershipTier      MembershipTier     @default(FREE)
  membershipExpiresAt DateTime?
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verificationBadge   Boolean            @default(false)
  isFeatured          Boolean            @default(false)
  profileViews        Int                @default(0)
  leadCount           Int                @default(0)
  responseRate        Decimal            @default(0.0)
  avgRating           Decimal            @default(0.0)
  reviewCount         Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfessionalProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  professionalType    ProfessionalType
  fullName            String
  title               String?
  licenseNumber       String?
  certifications      Json?
  education           String?
  profileImageUrl     String?
  coverImageUrl       String?
  bio                 String?
  yearExperience      Int?
  country             String             @default("Tanzania")
  city                String?
  website             String?
  whatsappNumber      String?
  membershipTier      MembershipTier     @default(FREE)
  membershipExpiresAt DateTime?
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verificationBadge   Boolean            @default(false)
  profileViews        Int                @default(0)
  leadCount           Int                @default(0)
  avgRating           Decimal            @default(0.0)
  reviewCount         Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([professionalType])
  @@index([city])
  @@index([verificationStatus])
  @@index([createdAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  icon        String?
  imageUrl    String?
  parentId    String?
  level       Int        @default(0)
  displayOrder Int       @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]
  rfqs     RFQ[]
}

model Product {
  id              String   @id @default(cuid())
  supplierId      String
  categoryId      String
  name            String
  slug            String   @unique
  description     String?
  shortDescription String?
  specifications  Json?
  price           Decimal?
  priceCurrency   String   @default("USD")
  moq             Int?
  unit            String?
  images          Json?
  videoUrl        String?
  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  viewsCount      Int      @default(0)
  inquiryCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id])

  @@index([supplierId])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([price])
  @@index([categoryId, isActive])
  @@index([supplierId, isActive])
}

model RFQ {
  id               String   @id @default(cuid())
  buyerId          String
  categoryId       String
  title            String
  description      String?
  documents        Json?
  budgetMin        Decimal?
  budgetMax        Decimal?
  currency         String   @default("USD")
  quantity         Int?
  unit             String?
  deliveryLocation String?
  deliveryTimeline String?
  status           RFQStatus @default(OPEN)
  visibility       String   @default("public")
  invitedSuppliers Json?
  responseCount    Int      @default(0)
  createdAt        DateTime @default(now())
  closedAt         DateTime?
  updatedAt        DateTime @updatedAt

  buyer   User    @relation(fields: [buyerId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  quotes  Quote[]

  @@index([buyerId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Quote {
  id               String     @id @default(cuid())
  rfqId            String
  supplierId       String
  price            Decimal
  currency         String     @default("USD")
  deliveryTimeline String?
  paymentTerms     String?
  notes            String?
  documents        Json?
  status           QuoteStatus @default(PENDING)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  rfq      RFQ             @relation(fields: [rfqId], references: [id])
  supplier SupplierProfile @relation(fields: [supplierId], references: [id])
  orders   Order[]

  @@index([rfqId])
  @@index([supplierId])
  @@index([status])
}

model Order {
  id              String      @id @default(cuid())
  quoteId         String?
  buyerId         String
  supplierId      String
  orderNumber     String      @unique
  totalAmount     Decimal
  currency        String      @default("USD")
  status          OrderStatus @default(CONFIRMED)
  shippingAddress String?
  deliveryDate    DateTime?
  trackingInfo    String?
  paymentStatus   String?
  paymentMethod   String?
  transactionFee  Decimal     @default(0)
  platformFee     Decimal     @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  quote    Quote?           @relation(fields: [quoteId], references: [id])
  buyer    User             @relation("BuyerOrders", fields: [buyerId], references: [id])
  supplier SupplierProfile  @relation("SupplierOrders", fields: [supplierId], references: [id])
  reviews  Review[]
  transactions Transaction[]

  @@index([buyerId])
  @@index([supplierId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([buyerId, status])
  @@index([supplierId, status])
}

model Review {
  id              String   @id @default(cuid())
  reviewerId      String
  revieweeType    String
  revieweeId      String
  orderId         String?
  rating          Int
  title           String?
  description     String?
  images          Json?
  isVerifiedPurchase Boolean @default(false)
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviewer User  @relation("Reviewer", fields: [reviewerId], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])

  @@index([revieweeType, revieweeId])
  @@index([reviewerId])
  @@index([orderId])
  @@index([isApproved])
  @@index([createdAt])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  rfqId      String?
  orderId    String?
  subject    String?
  body       String   @db.Text
  attachments Json?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("Sender", fields: [senderId], references: [id])
  receiver User @relation("Receiver", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([rfqId])
  @@index([orderId])
  @@index([isRead])
  @@index([createdAt])
}

model Project {
  id          String   @id @default(cuid())
  buyerId     String
  title       String
  slug        String   @unique
  description String?
  projectType String?
  category    String?
  budget      Decimal?
  currency    String   @default("USD")
  location    String?
  timelineStart DateTime?
  timelineEnd   DateTime?
  documents   Json?
  images      Json?
  status      String   @default("draft")
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buyer User @relation(fields: [buyerId], references: [id])
}

model Transaction {
  id             String   @id @default(cuid())
  orderId        String?
  userId         String?
  type           String
  amount         Decimal
  currency       String   @default("USD")
  status         String   @default("pending")
  paymentMethod  String?
  paymentProvider String?
  paymentId      String?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model VerificationRequest {
  id          String             @id @default(cuid())
  userId      String
  profileType String
  documents   Json?
  status      VerificationStatus @default(PENDING)
  adminNotes  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id             String         @id @default(cuid())
  userId         String
  profileType    String
  tier           MembershipTier
  status         String         @default("active")
  price          Decimal
  currency       String         @default("USD")
  interval       String         @default("monthly")
  startedAt      DateTime       @default(now())
  expiresAt      DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ManualPayment {
  id                 String               @id @default(cuid())
  userId             String
  plan               MembershipTier
  amount             Decimal
  currency           String               @default("USD")
  receiptUrl         String?
  receiptFileName    String?
  transactionRef     String?
  bankName           String?
  notes              String?
  status             PaymentRequestStatus @default(PENDING)
  adminNotes         String?
  reviewedBy         String?
  reviewedAt         DateTime?
  activatedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  itemId    String
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, itemType, itemId])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  sessionId  String?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum ScoutType {
  SUPPLIER
  CONTRACTOR
  PROFESSIONAL
  PRODUCT
  OUTREACH
  VERIFICATION
  PROJECT
  INTERNATIONAL
}

enum LeadStatus {
  DISCOVERED
  VERIFIED
  REVIEW_PENDING
  APPROVED
  REJECTED
  IMPORTED
  MERGED
}

enum TrustLevel {
  LOW
  MEDIUM
  HIGH
}

enum ActivationStatus {
  NONE
  UNCLAIMED
  CLAIMED
  VERIFIED
  FEATURED
}

enum WhatsAppStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLAIMED
  FAILED
}

enum FoundingStage {
  INVITED
  CLAIMED
  VERIFIED
  FEATURED
}

model GrowthAgent {
  id          String    @id @default(cuid())
  name        String
  type        ScoutType
  description String?
  config      Json?
  schedule    String?
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  totalRuns   Int       @default(0)
  totalLeads  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  runs         ScoutRun[]
  discoveredLeads DiscoveredLead[]

  @@index([type])
  @@index([isActive])
}

model ScoutRun {
  id         String     @id @default(cuid())
  agentId    String
  startedAt  DateTime   @default(now())
  completedAt DateTime?
  status     String     @default("running")
  recordsFound Int      @default(0)
  recordsScored Int     @default(0)
  errors     Json?
  log        String?
  duration   Int?

  agent GrowthAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  leads DiscoveredLead[]

  @@index([agentId])
  @@index([status])
  @@index([startedAt])
}

model DiscoveredLead {
  id                String           @id @default(cuid())
  agentId           String
  scoutRunId        String?
  sourceUrl         String?
  sourcePlatform    String?
  leadType          String
  companyName       String?
  contactName       String?
  email             String?
  phone             String?
  website           String?
  location          String?
  country           String?
  city              String?
  description       String?
  categorySlug      String?
  categoryLabels    Json?
  products          Json?
  socialProfiles    Json?
  verificationData  Json?
  trustScore        Int              @default(0)
  trustLevel        TrustLevel       @default(LOW)
  status            LeadStatus       @default(DISCOVERED)
  duplicateOf       String?
  duplicateScore    Int?
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?
  importedAt        DateTime?
  importedId        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Activation fields
  activationStatus    ActivationStatus @default(NONE)
  claimToken          String?          @unique
  claimLinkSentAt     DateTime?
  claimPageVisitedAt  DateTime?
  claimedAt           DateTime?
  claimedByUserId     String?
  claimedByEmail      String?
  verifiedAt          DateTime?
  featuredAt          DateTime?

  // Social discovery fields
  instagramUrl      String?
  facebookUrl       String?
  linkedinUrl       String?
  followers         Int?
  sources           Json?

  agent    GrowthAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scoutRun ScoutRun?   @relation(fields: [scoutRunId], references: [id])

  whatsappMessages   WhatsAppMessage[]
  foundingEntry      FoundingSupplier?

  @@index([agentId])
  @@index([status])
  @@index([activationStatus])
  @@index([trustLevel])
  @@index([email])
  @@index([companyName])
  @@index([leadType])
  @@index([categorySlug])
  @@index([country])
  @@index([status, trustLevel])
  @@index([activationStatus, status])
  @@index([instagramUrl])
  @@index([facebookUrl])
  @@index([linkedinUrl])
}

model WhatsAppMessage {
  id          String         @id @default(cuid())
  leadId      String
  channel     String         @default("whatsapp")
  messageType String         @default("activation")
  status      WhatsAppStatus @default(PENDING)
  claimLink   String?
  content     String?
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  claimedAt   DateTime?
  failedAt    DateTime?
  errorLog    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  lead DiscoveredLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([messageType])
  @@index([status, leadId])
}

model FoundingSupplier {
  id          String        @id @default(cuid())
  leadId      String        @unique
  stage       FoundingStage @default(INVITED)
  invitedAt   DateTime      @default(now())
  claimedAt   DateTime?
  verifiedAt  DateTime?
  featuredAt  DateTime?
  campaign    String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lead DiscoveredLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([stage])
  @@index([campaign])
  @@index([stage, campaign])
}

// ============================================================================
// PRICE INTELLIGENCE ENGINE
// docs/17-price-intelligence-architecture.md
// docs/18-price-intelligence-schema.md
// ============================================================================

enum RegionCode {
  ZNZ // Zanzibar
  DSM // Dar es Salaam
  ARU // Arusha
  DOD // Dodoma
  MWZ // Mwanza
}

enum MaterialCategorySlug {
  CEMENT
  REBARS
  BRC
  CONCRETE
  AGGREGATES
  BLOCKS
  BRICKS
  ROOFING
  TILES
  PAINT
  TIMBER
  ALUMINIUM
  GLASS
  FURNITURE
  HOSPITALITY_FFE
  COMMERCIAL_KITCHENS
}

enum PriceSource {
  APIFY_SCRAPER
  SUPPLIER_SUBMISSION
  ADMIN_SEED
  AI_EXTRACTION
  PARTNER_FEED
  MANUAL
}

enum ObservationStatus {
  ACTIVE
  STALE
  REJECTED
  PENDING_REVIEW
}

enum QualityTier {
  BASIC
  MID
  PREMIUM
}

enum ProjectType {
  VILLA
  HOTEL
  RESORT
  RESIDENTIAL_BLOCK
  OFFICE
  WAREHOUSE
  COMMERCIAL
  HOSPITALITY_FITOUT
  RENOVATION
  CUSTOM
}

enum BOQDocumentStatus {
  RECEIVED
  PARSING
  PARSED
  NEEDS_REVIEW
  FAILED
}

enum BOQDocumentKind {
  EXCEL
  CSV
  PDF_TEXT
  PDF_SCANNED
  IMAGE
  MANUAL_PASTE
}

enum ProcurementTaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETE
  SKIPPED
}

enum ProcurementTaskKind {
  RFQ_AWARDED
  PO_ISSUED
  SUPPLIER_CONFIRMED
  PRODUCTION
  SHIPPED
  IN_TRANSIT_CUSTOMS
  DELIVERED
  SITE_RECEIVED
  SIGNED_OFF
  CUSTOM
}

model Region {
  id          String     @id @default(cuid())
  code        RegionCode @unique
  name        String
  country     String     @default("Tanzania")
  centerLat   Decimal?
  centerLng   Decimal?
  isActive    Boolean    @default(true)
  displayOrder Int       @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  prices            PriceObservation[]
  indices           MaterialPriceIndex[]
  materialSuppliers MaterialSupplier[]
  estimates         ProjectEstimate[]
  costBenchmarks    CostBenchmark[]
  schedules         MaterialSchedule[]

  @@index([isActive])
}

model MaterialCategoryRef {
  id           String                @id @default(cuid())
  slug         MaterialCategorySlug  @unique
  name         String
  description  String?
  icon         String?
  parentSlug   String?
  isHospitality Boolean              @default(false)
  displayOrder Int                   @default(0)
  // typical share-of-budget across project types, JSON keyed by project type
  // e.g. { "VILLA": 0.08, "HOTEL": 0.06 }
  shareByProjectType Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  materials Material[]

  @@index([isHospitality])
}

model Material {
  id              String                @id @default(cuid())
  slug            String                @unique
  name            String
  categorySlug    MaterialCategorySlug
  spec            String?
  unit            String
  baseUnitFactor  Decimal               @default(1)
  description     String?
  imageUrl        String?
  // example aliases / synonyms for BOQ matching
  aliases         Json?
  isActive        Boolean               @default(true)
  displayOrder    Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  category MaterialCategoryRef @relation(fields: [categorySlug], references: [slug])
  variants MaterialVariant[]
  observations PriceObservation[]
  indices  MaterialPriceIndex[]
  materialSuppliers MaterialSupplier[]
  scheduleItems    ScheduleLineItem[]
  estimateItems    EstimateLineItem[]
  alertSubscriptions PriceAlert[]

  @@index([categorySlug])
  @@index([isActive])
  @@index([categorySlug, isActive])
}

model MaterialVariant {
  id          String   @id @default(cuid())
  materialId  String
  brand       String?
  sku         String?
  spec        String?
  unit        String?
  imageUrl    String?
  attributes  Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  material      Material           @relation(fields: [materialId], references: [id], onDelete: Cascade)
  observations  PriceObservation[]
  materialSuppliers MaterialSupplier[]

  @@unique([materialId, brand, spec])
  @@index([materialId])
  @@index([brand])
}

model PriceObservation {
  id             String            @id @default(cuid())
  materialId     String
  variantId      String?
  regionId       String
  source         PriceSource
  sourceUrl      String?
  supplierId     String?
  observedAt     DateTime          @default(now())
  unitPrice      Decimal
  currency       String            @default("TZS")
  quantity       Decimal           @default(1)
  unit           String?
  vatIncluded    Boolean           @default(true)
  notes          String?
  rawPayload     Json?
  confidence     Int               @default(50)
  status         ObservationStatus @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  material Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  variant  MaterialVariant? @relation(fields: [variantId], references: [id])
  region   Region           @relation(fields: [regionId], references: [id])

  @@index([materialId])
  @@index([variantId])
  @@index([regionId])
  @@index([status])
  @@index([observedAt])
  @@index([materialId, regionId, status])
  @@index([materialId, regionId, observedAt])
}

model MaterialPriceIndex {
  id           String   @id @default(cuid())
  materialId   String
  regionId     String
  periodStart  DateTime
  periodEnd    DateTime
  granularity  String   @default("daily")
  currency     String   @default("TZS")
  unit         String?
  p25          Decimal?
  median       Decimal?
  p75          Decimal?
  mean         Decimal?
  stddev       Decimal?
  sampleSize   Int      @default(0)
  changePct    Decimal?
  confidence   Int      @default(0)
  createdAt    DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  region   Region   @relation(fields: [regionId], references: [id])

  @@unique([materialId, regionId, periodStart, granularity])
  @@index([materialId, regionId, granularity])
  @@index([periodStart])
}

model MaterialSupplier {
  id                String   @id @default(cuid())
  supplierProfileId String
  materialId        String
  variantId         String?
  regionId          String
  unitPrice         Decimal?
  currency          String   @default("TZS")
  unit              String?
  stockStatus       String   @default("UNKNOWN")
  leadTimeDays      Int?
  minOrderQty       Decimal?
  deliveryRadiusKm  Int?
  lastPricedAt      DateTime?
  notes             String?
  isFeatured        Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  material Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  variant  MaterialVariant? @relation(fields: [variantId], references: [id])
  region   Region           @relation(fields: [regionId], references: [id])

  @@unique([supplierProfileId, materialId, variantId, regionId])
  @@index([supplierProfileId])
  @@index([materialId, regionId, isActive])
  @@index([regionId])
}

model CostBenchmark {
  id              String      @id @default(cuid())
  regionId        String
  projectType     ProjectType
  qualityTier     QualityTier
  sqmCostMedian   Decimal
  sqmCostP25      Decimal?
  sqmCostP75      Decimal?
  currency        String      @default("USD")
  source          String?
  effectiveFrom   DateTime    @default(now())
  effectiveTo     DateTime?
  isActive        Boolean     @default(true)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  region Region @relation(fields: [regionId], references: [id])

  @@unique([regionId, projectType, qualityTier, effectiveFrom])
  @@index([regionId, projectType, qualityTier, isActive])
}

model ProjectEstimate {
  id              String      @id @default(cuid())
  buyerId         String?
  sessionRef      String?
  projectName     String?
  projectType     ProjectType
  qualityTier     QualityTier
  regionId        String
  builtUpAreaSqm  Decimal
  budgetMin       Decimal?
  budgetMedian    Decimal?
  budgetMax       Decimal?
  currency        String      @default("USD")
  assumptions     Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  region    Region              @relation(fields: [regionId], references: [id])
  lineItems EstimateLineItem[]

  @@index([buyerId])
  @@index([projectType, regionId])
  @@index([createdAt])
}

model EstimateLineItem {
  id              String   @id @default(cuid())
  estimateId      String
  materialId      String?
  categorySlug    MaterialCategorySlug
  label           String
  qty             Decimal
  unit            String?
  unitPriceMedian Decimal?
  costMedian      Decimal?
  costMin         Decimal?
  costMax         Decimal?
  sharePct        Decimal?
  notes           String?
  createdAt       DateTime @default(now())

  estimate ProjectEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  material Material?       @relation(fields: [materialId], references: [id])

  @@index([estimateId])
  @@index([categorySlug])
}

model BOQDocument {
  id              String            @id @default(cuid())
  buyerId         String?
  projectId       String?
  filename        String?
  fileUrl         String?
  kind            BOQDocumentKind
  status          BOQDocumentStatus @default(RECEIVED)
  rawText         String?           @db.Text
  parsed          Json?
  parseError      String?
  itemCount       Int               @default(0)
  matchedCount    Int               @default(0)
  costEstimateTzs Decimal?
  costEstimateUsd Decimal?
  uploadedAt      DateTime          @default(now())
  parsedAt        DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  schedules MaterialSchedule[]

  @@index([buyerId])
  @@index([projectId])
  @@index([status])
}

model MaterialSchedule {
  id              String   @id @default(cuid())
  buyerId         String?
  projectId       String?
  boqDocumentId   String?
  regionId        String
  title           String?
  notes           String?
  totalsByCategory Json?
  grandTotalTzs   Decimal?
  grandTotalUsd   Decimal?
  currency        String   @default("TZS")
  status          String   @default("DRAFT")
  exportedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  region      Region              @relation(fields: [regionId], references: [id])
  boqDocument BOQDocument?        @relation(fields: [boqDocumentId], references: [id])
  lineItems   ScheduleLineItem[]
  procurementPlans ProcurementPlan[]

  @@index([buyerId])
  @@index([projectId])
  @@index([regionId])
  @@index([status])
  @@index([createdAt])
}

model ScheduleLineItem {
  id              String   @id @default(cuid())
  scheduleId      String
  materialId      String?
  description     String
  categorySlug    MaterialCategorySlug?
  qty             Decimal
  unit            String?
  unitPriceMedian Decimal?
  unitPriceLow    Decimal?
  unitPriceHigh   Decimal?
  costMedian      Decimal?
  currency        String   @default("TZS")
  topSuppliers    Json?
  matchScore      Decimal?
  needsReview     Boolean  @default(false)
  position        Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())

  schedule MaterialSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  material Material?        @relation(fields: [materialId], references: [id])

  @@index([scheduleId])
  @@index([materialId])
  @@index([categorySlug])
  @@index([needsReview])
}

model ProcurementPlan {
  id              String   @id @default(cuid())
  buyerId         String
  projectId       String?
  scheduleId      String?
  title           String
  description     String?
  status          String   @default("ACTIVE")
  totalBudgetTzs  Decimal?
  totalBudgetUsd  Decimal?
  currency        String   @default("TZS")
  startDate       DateTime?
  targetEndDate   DateTime?
  actualEndDate   DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedule MaterialSchedule? @relation(fields: [scheduleId], references: [id])
  tasks    ProcurementTask[]

  @@index([buyerId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model ProcurementTask {
  id              String                @id @default(cuid())
  planId          String
  kind            ProcurementTaskKind
  title           String
  description     String?
  status          ProcurementTaskStatus @default(PENDING)
  rfqId           String?
  orderId         String?
  supplierId      String?
  assigneeId      String?
  dueDate         DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  position        Int                   @default(0)
  attachments     Json?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  plan ProcurementPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([status])
  @@index([kind])
  @@index([planId, status])
  @@index([dueDate])
}

model PriceAlert {
  id              String   @id @default(cuid())
  userId          String
  materialId      String
  regionId        String?
  thresholdPct    Decimal  @default(5)
  direction       String   @default("ANY")
  isActive        Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([materialId])
  @@index([isActive])
}
